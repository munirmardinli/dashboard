{
	"name": "dashboard-api",
	"version": "0.1.0",
	"private": true,
	"description": "Node.js HTTP API Server für Dashboard-Management",
	"type": "module",
	"main": "dist/src/index.js",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"start": "node dist/src/index.js",
		"lint": "echo 'No linting configured'",
		"build": "rm -rf ./dist/src/graphql/schemes && npm run copy-schemes && tsc",
		"copy-schemes": "copyfiles -f src/graphql/schemes/*.graphql dist/src/graphql/schemes",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@apollo/server": "^4.9.5",
		"@graphql-tools/graphql-file-loader": "^8.0.0",
		"@graphql-tools/load": "^8.0.0",
		"@graphql-tools/merge": "^9.0.0",
		"cors": "2.8.6",
		"dotenv": "17.3.1",
		"express": "^4.18.2",
		"graphql": "^16.8.1",
		"graphql-scalars": "^1.22.2",
		"graphql-upload": "^16.0.2",
		"ical-generator": "10.1.0",
		"twilio": "5.13.0"
	},
	"devDependencies": {
		"@graphql-codegen/cli": "^5.0.0",
		"@graphql-codegen/typescript": "^4.0.1",
		"@graphql-codegen/typescript-resolvers": "^4.0.1",
		"@types/cors": "2.8.19",
		"@types/express": "4.17.25",
		"@types/graphql-upload": "17.0.0",
		"@types/node": "^25.5.0",
		"copyfiles": "^2.4.1",
		"tsx": "^4.21.0",
		"typescript": "^5"
	}
}
